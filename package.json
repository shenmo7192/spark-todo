{
  "name": "spark-todo",
  "version": "1.2.1",
  "description": "Todo 工单系统台账生成器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "shenmo <jifengshenmo@outlook.com>",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^10.0.0",
    "electron": "^22.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^8.0.14",
    "vue": "^3.5.35",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.spark.todo",
    "productName": "Spark Todo 星火工单系统",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "export.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      "data/**/*"
    ],
    "linux": {
      "target": ["deb"],
      "category": "Utility",
      "icon": "build/icons"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
