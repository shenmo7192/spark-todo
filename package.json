{
  "name": "spark-todo",
  "version": "1.0.0",
  "description": "Todo 工单系统台账生成器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Spark",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.spark.todo",
    "productName": "SparkTodo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "export.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "node_modules/**/*"
    ],
    "extraResources": [
      "data/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
